# Environment Configuration
# Copy this file to .env and update values for your environment

# Environment (development, staging, production)
ENV=production

# API Configuration
API_BASE_URL=https://api.gemstone-app.com
API_TIMEOUT=30

# Database Configuration
DATABASE_NAME=gemstone_app.db
DATABASE_VERSION=1

# Offline Mode
OFFLINE_MODE_ENABLED=true
REQUIRE_BACKEND_ON_STARTUP=false

# Sync Configuration
AUTO_SYNC_ENABLED=true
SYNC_INTERVAL_MINUTES=5
MAX_SYNC_RETRIES=3
SYNC_TIMEOUT_SECONDS=30

# Security Configuration
REQUIRE_AUTHENTICATION=true
SESSION_TIMEOUT_MINUTES=30
ENABLE_DATA_ENCRYPTION=true
HTTPS_ONLY=true

# Feature Flags
FEATURE_INVENTORY=true
FEATURE_SALES=true
FEATURE_EXPENSES=true
FEATURE_REPORTS=true
FEATURE_WORKERS=true
FEATURE_QR_TRACKING=true
FEATURE_NOTIFICATIONS=true
FEATURE_SYNC=true

# Logging
DEBUG_LOGGING=true
LOG_LEVEL=1

# Performance
ENABLE_IMAGE_CACHE=true
IMAGE_CACHE_SIZE=100
ENABLE_QUERY_OPTIMIZATION=true
BATCH_SIZE=100

# Analytics
ENABLE_ANALYTICS=true
ANALYTICS_ENDPOINT=https://analytics.gemstone-app.com

# Build Information
APP_VERSION=1.0.0
BUILD_NUMBER=1
